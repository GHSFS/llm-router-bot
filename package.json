{
  "name": "llm-router-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-provider LLM router that fronts Telegram and Discord bots from a single Cloudflare Worker.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"{src,test}/**/*.ts\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
